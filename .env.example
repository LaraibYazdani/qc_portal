# ─── Database (Aiven MySQL) ────────────────────────────────────────────────────
DB_HOST=mysql-xxxxxxxx.aivencloud.com
DB_PORT=12345
DB_NAME=qc_portal
DB_USER=avnadmin
DB_PASS=your_aiven_password

# Paste the full contents of the Aiven CA certificate here (including header/footer lines).
# Download it from: Aiven Console → your service → "Connection information" → CA Certificate.
# In Vercel: add this as a multi-line environment variable (Vercel supports it).
DB_SSL_CA="-----BEGIN CERTIFICATE-----
MIIEQTCCAqmgAwIBAgIU...
-----END CERTIFICATE-----"

# ─── Application ───────────────────────────────────────────────────────────────
# Leave empty for Vercel (served at root). Use /qc_portal/public for local XAMPP.
APP_BASE_URL=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Found in: Cloudinary Console → Dashboard → "API Keys"
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Cloudinary folder where designs are stored (default: qc_jobs)
CLOUDINARY_FOLDER=qc_jobs
